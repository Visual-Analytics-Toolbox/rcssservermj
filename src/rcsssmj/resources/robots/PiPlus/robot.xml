    <velocity name="lae4_vel" joint="l_elbow_joint"/>

    <!-- 14: r_calf -->
    <motor name="rle4_tau" joint="r_calf_joint"/>
    <position name="rle4_pos" joint="r_calf_joint"/>
    <velocity name="rle4_vel" joint="r_calf_joint"/>

    <!-- 15: r_elbow -->
    <motor name="rae4_tau" joint="r_elbow_joint"/>
    <position name="rae4_pos" joint="r_elbow_joint"/>
    <velocity name="rae4_vel" joint="r_elbow_joint"/>

    <!-- 16: l_ankle_pitch -->
    <motor name="lle5_tau" joint="l_ankle_pitch_joint"/>
    <position name="lle5_pos" joint="l_ankle_pitch_joint"/>
    <velocity name="lle5_vel" joint="l_ankle_pitch_joint"/>

    <!-- 17: r_ankle_pitch -->
    <motor name="rle5_tau" joint="r_ankle_pitch_joint"/>
    <position name="rle5_pos" joint="r_ankle_pitch_joint"/>
    <velocity name="rle5_vel" joint="r_ankle_pitch_joint"/>

    <!-- 18: l_ankle_roll -->
    <motor name="lle6_tau" joint="l_ankle_roll_joint"/>
    <position name="lle6_pos" joint="l_ankle_roll_joint"/>
    <velocity name="lle6_vel" joint="l_ankle_roll_joint"/>

    <!-- 19: r_ankle_roll -->
    <motor name="rle6_tau" joint="r_ankle_roll_joint"/>
    <position name="rle6_pos" joint="r_ankle_roll_joint"/>
    <velocity name="rle6_vel" joint="r_ankle_roll_joint"/>

    <!-- 20-22: extra (not controlled by ONNX) -->
    <motor name="he1_tau" joint="head_yaw_joint"/>
    <position name="he1_pos" joint="head_yaw_joint"/>
    <velocity name="he1_vel" joint="head_yaw_joint"/>

    <motor name="he2_tau" joint="head_pitch_joint"/>
    <position name="he2_pos" joint="head_pitch_joint"/>
    <velocity name="he2_vel" joint="head_pitch_joint"/>

    <motor name="te1_tau" joint="waist_yaw_joint"/>
    <position name="te1_pos" joint="waist_yaw_joint"/>
    <velocity name="te1_vel" joint="waist_yaw_joint"/>
  </actuator>

  <sensor>
    <framequat name="torso_quat" objtype="site" objname="torso"/>
    <framepos name="torso_pos" objtype="site" objname="torso"/>

    <gyro name="torso_gyro" site="torso"/>
    <accelerometer name="torso_acc" site="torso"/>

    <!-- joint position sensors: ONNX order (20 dims) then 3 extra -->
    <jointpos name="q_llj1" joint="l_hip_pitch_joint"/>       <!-- 0 -->
    <jointpos name="q_laj1" joint="l_shoulder_pitch_joint"/>   <!-- 1 -->
    <jointpos name="q_rlj1" joint="r_hip_pitch_joint"/>        <!-- 2 -->
    <jointpos name="q_raj1" joint="r_shoulder_pitch_joint"/>    <!-- 3 -->
    <jointpos name="q_llj2" joint="l_hip_roll_joint"/>          <!-- 4 -->
    <jointpos name="q_laj2" joint="l_shoulder_roll_joint"/>     <!-- 5 -->
    <jointpos name="q_rlj2" joint="r_hip_roll_joint"/>          <!-- 6 -->
    <jointpos name="q_raj2" joint="r_shoulder_roll_joint"/>     <!-- 7 -->
    <jointpos name="q_llj3" joint="l_thigh_joint"/>             <!-- 8 -->
    <jointpos name="q_laj3" joint="l_upper_arm_joint"/>         <!-- 9 -->
    <jointpos name="q_rlj3" joint="r_thigh_joint"/>             <!-- 10 -->
    <jointpos name="q_raj3" joint="r_upper_arm_joint"/>         <!-- 11 -->
    <jointpos name="q_llj4" joint="l_calf_joint"/>              <!-- 12 -->
    <jointpos name="q_laj4" joint="l_elbow_joint"/>             <!-- 13 -->
    <jointpos name="q_rlj4" joint="r_calf_joint"/>              <!-- 14 -->
    <jointpos name="q_raj4" joint="r_elbow_joint"/>             <!-- 15 -->
    <jointpos name="q_llj5" joint="l_ankle_pitch_joint"/>       <!-- 16 -->
    <jointpos name="q_rlj5" joint="r_ankle_pitch_joint"/>       <!-- 17 -->
    <jointpos name="q_llj6" joint="l_ankle_roll_joint"/>        <!-- 18 -->
    <jointpos name="q_rlj6" joint="r_ankle_roll_joint"/>        <!-- 19 -->
    <jointpos name="q_hj1" joint="head_yaw_joint"/>             <!-- 20 extra -->
    <jointpos name="q_hj2" joint="head_pitch_joint"/>           <!-- 21 extra -->
    <jointpos name="q_tj1" joint="waist_yaw_joint"/>            <!-- 22 extra -->

    <!-- joint velocity sensors: same ONNX order -->
    <jointvel name="dq_llj1" joint="l_hip_pitch_joint"/>       <!-- 0 -->
    <jointvel name="dq_laj1" joint="l_shoulder_pitch_joint"/>   <!-- 1 -->
    <jointvel name="dq_rlj1" joint="r_hip_pitch_joint"/>        <!-- 2 -->
    <jointvel name="dq_raj1" joint="r_shoulder_pitch_joint"/>    <!-- 3 -->
    <jointvel name="dq_llj2" joint="l_hip_roll_joint"/>          <!-- 4 -->
    <jointvel name="dq_laj2" joint="l_shoulder_roll_joint"/>     <!-- 5 -->
    <jointvel name="dq_rlj2" joint="r_hip_roll_joint"/>          <!-- 6 -->
    <jointvel name="dq_raj2" joint="r_shoulder_roll_joint"/>     <!-- 7 -->
    <jointvel name="dq_llj3" joint="l_thigh_joint"/>             <!-- 8 -->
    <jointvel name="dq_laj3" joint="l_upper_arm_joint"/>         <!-- 9 -->
    <jointvel name="dq_rlj3" joint="r_thigh_joint"/>             <!-- 10 -->
    <jointvel name="dq_raj3" joint="r_upper_arm_joint"/>         <!-- 11 -->
    <jointvel name="dq_llj4" joint="l_calf_joint"/>              <!-- 12 -->
    <jointvel name="dq_laj4" joint="l_elbow_joint"/>             <!-- 13 -->
    <jointvel name="dq_rlj4" joint="r_calf_joint"/>              <!-- 14 -->
    <jointvel name="dq_raj4" joint="r_elbow_joint"/>             <!-- 15 -->
    <jointvel name="dq_llj5" joint="l_ankle_pitch_joint"/>       <!-- 16 -->
    <jointvel name="dq_rlj5" joint="r_ankle_pitch_joint"/>       <!-- 17 -->
    <jointvel name="dq_llj6" joint="l_ankle_roll_joint"/>        <!-- 18 -->
    <jointvel name="dq_rlj6" joint="r_ankle_roll_joint"/>        <!-- 19 -->
    <jointvel name="dq_hj1" joint="head_yaw_joint"/>             <!-- 20 extra -->
    <jointvel name="dq_hj2" joint="head_pitch_joint"/>           <!-- 21 extra -->
    <jointvel name="dq_tj1" joint="waist_yaw_joint"/>            <!-- 22 extra -->
  </sensor>

  <contact>
    <exclude body1="r_hip_roll_link" body2="r_calf_link"/>
    <exclude body1="r_calf_link" body2="r_ankle_roll_link"/>
    <exclude body1="l_hip_roll_link" body2="l_calf_link"/>
    <exclude body1="l_calf_link" body2="l_ankle_roll_link"/>
  </contact>
</mujoco>
