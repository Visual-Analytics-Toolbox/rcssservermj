    <position name="lae2_pos" joint="l_shoulder_roll_joint"/>
    <velocity name="lae2_vel" joint="l_shoulder_roll_joint"/>

    <!-- 6: r_hip_roll -->
    <motor name="rle2_tau" joint="r_hip_roll_joint"/>
    <position name="rle2_pos" joint="r_hip_roll_joint"/>
    <velocity name="rle2_vel" joint="r_hip_roll_joint"/>

    <!-- 7: r_shoulder_roll -->
    <motor name="rae2_tau" joint="r_shoulder_roll_joint"/>
    <position name="rae2_pos" joint="r_shoulder_roll_joint"/>
    <velocity name="rae2_vel" joint="r_shoulder_roll_joint"/>

    <!-- 8: l_thigh -->
    <motor name="lle3_tau" joint="l_thigh_joint"/>
    <position name="lle3_pos" joint="l_thigh_joint"/>
    <velocity name="lle3_vel" joint="l_thigh_joint"/>

    <!-- 9: l_upper_arm -->
    <motor name="lae3_tau" joint="l_upper_arm_joint"/>
    <position name="lae3_pos" joint="l_upper_arm_joint"/>
    <velocity name="lae3_vel" joint="l_upper_arm_joint"/>

    <!-- 10: r_thigh -->
    <motor name="rle3_tau" joint="r_thigh_joint"/>
    <position name="rle3_pos" joint="r_thigh_joint"/>
    <velocity name="rle3_vel" joint="r_thigh_joint"/>

    <!-- 11: r_upper_arm -->
    <motor name="rae3_tau" joint="r_upper_arm_joint"/>
    <position name="rae3_pos" joint="r_upper_arm_joint"/>
    <velocity name="rae3_vel" joint="r_upper_arm_joint"/>

    <!-- 12: l_calf -->
    <motor name="lle4_tau" joint="l_calf_joint"/>
    <position name="lle4_pos" joint="l_calf_joint"/>
    <velocity name="lle4_vel" joint="l_calf_joint"/>

    <!-- 13: l_elbow -->
    <motor name="lae4_tau" joint="l_elbow_joint"/>
